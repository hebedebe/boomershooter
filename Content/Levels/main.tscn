[sub_resource type="GDScript" id="GDScript_nkux8"]
script/source = "extends Button

@onready var map: MapLoader = $\"../../..\"

func _ready() -> void:
	update_text()

func _pressed() -> void:
	map.next_index()
	update_text()

func update_text():
	var index = map.selected_index
	text = \"Map %s: %s\" % [index, map.maps[index].resource_path]
"

