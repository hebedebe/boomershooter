[sub_resource type="GDScript" id="GDScript_jxnjk"]
script/source = "extends Node3D

func _unhandled_input(_event: InputEvent) -> void:
	if Input.is_action_pressed(\"quit\"):
		get_tree().quit()
"

[sub_resource type="GDScript" id="GDScript_a50q2"]
script/source = "extends Camera3D

@export var rotation_speed: float = 0.3

@onready var network: NetworkManager = $\"../Network\"

func _ready() -> void:
	network.game_started.connect(func():current=false)

func _process(delta: float) -> void:
	rotation.y += delta * rotation_speed
"

[sub_resource type="GDScript" id="GDScript_vm62j"]
script/source = "extends CanvasLayer

@onready var network: NetworkManager = $\"../../Network\"

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	network.game_reset.connect(reset)
	network.game_started.connect(hide)
	print(\"Connected network signals\")
	
func reset():
	print(\"show map select\")
	show()
"

