[sub_resource type="GDScript" id="GDScript_rn1qw"]
script/source = "extends TextureRect

@onready var camera: PlayerCamera = $\"../../../../Neck/Camera\"

func _process(_delta: float) -> void:
	if camera:
		var local_velocity = camera.get_local_velocity()
		position = Vector2(local_velocity.x, local_velocity.z)
"

[sub_resource type="GDScript" id="GDScript_uei5y"]
script/source = "extends CanvasLayer


func _enter_tree() -> void:
	visible = is_multiplayer_authority()
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_rn1qw"]
shader = ExtResource("3_7d8p2")
shader_parameter/transparent_color = Color(1, 1, 1, 1)
shader_parameter/pickup_range = 1.0
shader_parameter/fade_amount = 0.5

[sub_resource type="GDScript" id="GDScript_1q6fh"]
script/source = "extends Label


func _enter_tree() -> void:
	text = \"ID: %s\" % $\"../../..\".name
"

[sub_resource type="GDScript" id="GDScript_2mypc"]
script/source = "extends Label


func _enter_tree() -> void:
	text = \"Username: %s\" % $\"../../..\".username
"

[sub_resource type="GDScript" id="GDScript_aak6e"]
script/source = "extends Label

func _process(_delta: float) -> void:
	var state: State = $\"../../../AttackStateController\".state
	if state:
		text = \"state: %s\" % state.name
	else:
		text = \"state: unset (this is a bug)\"
"

