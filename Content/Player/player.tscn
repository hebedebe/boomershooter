[sub_resource type="GDScript" id="GDScript_0femt"]
script/source = "extends ColorRect

@export var fall_speed: float = 1

@onready var broken_glass_sfx: AudioStreamPlayer = $BrokenGlassSFX

var falling: bool = false
var progress: float = 0

func _ready() -> void:
	visible = false

func _process(delta: float) -> void:
	if falling:
		if material is ShaderMaterial:
			material.set_shader_parameter(\"fall_progress\", progress)
			progress += delta * fall_speed;
			if progress >= 1:
				falling=false

func glass_fall():
	visible = true
	falling = true
	broken_glass_sfx.play()
	progress=0
"

